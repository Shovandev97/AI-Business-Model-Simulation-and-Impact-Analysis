<mvc:View
  controllerName="bms.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core">
  <VBox height="100%">
    <f:ShellBar title="AI-Powered Business Model Simulation" secondTitle="O2C Impact Analysis Engine" showCopilot="true" showNotifications="true">
      <f:profile>
        <Avatar initials="AI"/>
      </f:profile>
    </f:ShellBar>
    <App>
    <Page class="sapUiNoContentPadding appPage">
      <content>
        <HBox class="layoutRoot" width="100%">
          <VBox class="sideNav">
            <Title text="Navigation" level="H5"/>
            <Button icon="sap-icon://business-objects-experience" text="Dashboard" press=".onNav" data-key="dashboard" type="{parts:[{path:'app>/activePage'},{value:'dashboard'}], formatter:'.navType'}"/>
            <Button icon="sap-icon://create-form" text="Create Scenario" press=".onNav" data-key="create" type="{parts:[{path:'app>/activePage'},{value:'create'}], formatter:'.navType'}"/>
            <Button icon="sap-icon://journey-arrive" text="Impact Analysis" press=".onNav" data-key="impact" type="{parts:[{path:'app>/activePage'},{value:'impact'}], formatter:'.navType'}"/>
            <Button icon="sap-icon://compare" text="Compare Scenarios" press=".onNav" data-key="compare" type="{parts:[{path:'app>/activePage'},{value:'compare'}], formatter:'.navType'}"/>
            <Button icon="sap-icon://ai" text="AI Recommendation" press=".onNav" data-key="recommendation" type="{parts:[{path:'app>/activePage'},{value:'recommendation'}], formatter:'.navType'}"/>
            <Button icon="sap-icon://history" text="History" press=".onNav" data-key="audit" type="{parts:[{path:'app>/activePage'},{value:'audit'}], formatter:'.navType'}"/>
            <Button icon="sap-icon://settings" text="Settings" press=".onNav" data-key="admin" type="{parts:[{path:'app>/activePage'},{value:'admin'}], formatter:'.navType'}"/>
          </VBox>
          <ScrollContainer vertical="true" horizontal="false" class="contentPane">
            <VBox class="contentInner" renderType="Bare">
              <HBox class="toolbarBand" justifyContent="SpaceBetween" alignItems="Center">
                <VBox>
                  <Title text="Commercial Model Simulation Cockpit" level="H2"/>
                  <Text text="Assess revenue, risk, compliance and downstream process impact before model rollout."/>
                </VBox>
                <HBox alignItems="Center" visible="{= ${app>/activePage} !== 'create' }">
                  <Select selectedKey="{app>/selectedScenarioId}" items="{app>/scenarios}" change=".onSelectScenario" width="19rem">
                    <core:Item key="{app>id}" text="{app>name}"/>
                  </Select>
                  <Button text="Refresh" icon="sap-icon://refresh" type="Transparent" press=".onRefresh"/>
                </HBox>
              </HBox>

              <IconTabBar id="tabs" selectedKey="{app>/activePage}" expandable="false" class="workTabs singleNavContent">
                <items>
                  <IconTabFilter key="dashboard" icon="sap-icon://business-objects-experience" text="Dashboard">
                    <VBox class="pageStack">
                      <VBox class="dashboardEmpty panel" visible="{= !!${app>/dashboard/emptyState} }">
                        <Title text="{app>/dashboard/emptyState/title}" level="H3"/>
                        <Text text="{app>/dashboard/emptyState/message}"/>
                        <Button text="{app>/dashboard/emptyState/actionText}" icon="sap-icon://create-form" type="Emphasized" press=".goCreateScenario"/>
                      </VBox>

                      <VBox visible="{= !${app>/dashboard/emptyState} }" class="pageStack">
                        <VBox class="panel executivePanel">
                          <VBox>
                            <Title text="Executive Portfolio Overview" level="H3"/>
                            <Text text="Commercial model portfolio health, risk, effort and revenue opportunity based on analyzed scenarios."/>
                          </VBox>
                          <FlexBox wrap="Wrap" class="kpiRow">
                            <GenericTile header="Analyzed Scenarios" subheader="Impact history" class="kpiTile"><TileContent><NumericContent value="{app>/dashboard/executiveSummary/totalScenarios}" icon="sap-icon://documents"/></TileContent></GenericTile>
                            <GenericTile header="Average Risk" subheader="Predictive AI" class="kpiTile"><TileContent><NumericContent value="{app>/dashboard/executiveSummary/averageRiskScore}" scale="%" icon="sap-icon://risk-management"/></TileContent></GenericTile>
                            <GenericTile header="Average Effort" subheader="Implementation load" class="kpiTile"><TileContent><NumericContent value="{app>/dashboard/executiveSummary/averageEffortScore}" scale="%" icon="sap-icon://activity-individual"/></TileContent></GenericTile>
                            <GenericTile header="Revenue Opportunity" subheader="Average impact" class="kpiTile"><TileContent><NumericContent value="{app>/dashboard/executiveSummary/averageRevenueImpact}" scale="%" icon="sap-icon://line-chart"/></TileContent></GenericTile>
                          </FlexBox>
                        </VBox>

                        <HBox class="sectionGrid">
                          <VBox class="panel chartPanel">
                            <Title text="Business Model Portfolio Summary" level="H4"/>
                            <List items="{app>/dashboard/businessModelDistribution}" noDataText="No analyzed business models yet.">
                              <CustomListItem><VBox class="chartRow"><HBox justifyContent="SpaceBetween"><ObjectStatus text="{app>modelType}" state="Information"/><Text text="{app>count} scenarios | score {app>averageScore}"/></HBox><HBox class="barTrack"><HBox class="barFill impactBar" width="{path:'app>averageScore', formatter:'.pctWidth'}"/></HBox></VBox></CustomListItem>
                            </List>
                          </VBox>
                          <VBox class="panel chartPanel">
                            <Title text="Risk Distribution" level="H4"/>
                            <List items="{app>/dashboard/riskDistribution}" noDataText="No risk distribution yet.">
                              <CustomListItem><VBox class="chartRow"><HBox justifyContent="SpaceBetween"><Text text="{app>riskLevel}"/><ObjectNumber number="{app>count}"/></HBox><HBox class="barTrack"><HBox class="barFill riskBar" width="{path:'app>count', formatter:'.countWidth'}"/></HBox></VBox></CustomListItem>
                            </List>
                          </VBox>
                          <VBox class="panel chartPanel">
                            <Title text="Implementation Effort Breakdown" level="H4"/>
                            <List items="{app>/dashboard/implementationEffortBreakdown}" noDataText="No effort data yet.">
                              <CustomListItem><VBox class="chartRow"><HBox justifyContent="SpaceBetween"><Text text="{app>area}"/><ObjectNumber number="{app>averageEffort}" unit="%"/></HBox><HBox class="barTrack"><HBox class="barFill performanceBar" width="{path:'app>averageEffort', formatter:'.pctWidth'}"/></HBox></VBox></CustomListItem>
                            </List>
                          </VBox>
                        </HBox>

                        <HBox class="sectionGrid">
                          <VBox class="panel widePanel">
                            <Title text="Risk vs Revenue Opportunity" level="H4"/>
                            <Table items="{app>/dashboard/riskRevenueMatrix}" noDataText="No matrix data yet.">
                              <columns><Column><Text text="Scenario"/></Column><Column><Text text="Model"/></Column><Column><Text text="Risk"/></Column><Column><Text text="Effort"/></Column><Column><Text text="Revenue"/></Column><Column><Text text="Volume"/></Column><Column><Text text="Integrations"/></Column></columns>
                              <items><ColumnListItem><cells><ObjectIdentifier title="{app>scenarioName}" text="{app>scenarioId}"/><ObjectStatus text="{app>businessModelType}" state="Information"/><ObjectNumber number="{app>riskScore}" unit="%"/><ObjectNumber number="{app>effortScore}" unit="%"/><ObjectNumber number="{app>revenueImpact}" unit="%"/><ObjectNumber number="{app>transactionVolume}"/><ObjectNumber number="{app>integrationCount}"/></cells></ColumnListItem></items>
                            </Table>
                          </VBox>
                          <VBox class="panel topModelCard">
                            <Title text="Top Recommended Model" level="H4"/>
                            <ObjectStatus text="{app>/dashboard/topRecommendedModel/businessModelType}" state="Success"/>
                            <Title text="{app>/dashboard/topRecommendedModel/scenarioName}" level="H5"/>
                            <ObjectNumber number="{app>/dashboard/topRecommendedModel/recommendationScore}" unit="score"/>
                            <Text text="{app>/dashboard/topRecommendedModel/reasonSummary}"/>
                            <Text text="{app>/dashboard/topRecommendedModel/expectedBenefit}"/>
                            <Button text="View Recommendation" icon="sap-icon://ai" type="Transparent" press=".goRecommendation"/>
                          </VBox>
                        </HBox>

                        <HBox class="sectionGrid">
                          <VBox class="panel widePanel">
                            <Title text="O2C Impact Heatmap" level="H4"/>
                            <FlexBox wrap="Wrap" items="{app>/dashboard/o2cImpactHeatmap}" class="heatmapGrid">
                              <VBox class="heatCell">
                                <ObjectStatus text="{app>severity}" state="{app>state}"/>
                                <Title text="{app>area}" level="H5"/>
                                <ProgressIndicator percentValue="{app>averageImpactScore}" displayValue="{app>averageImpactScore}%"/>
                              </VBox>
                            </FlexBox>
                          </VBox>
                        </HBox>

                      <HBox class="sectionGrid">
                        <VBox class="panel widePanel">
                          <HBox justifyContent="SpaceBetween" alignItems="Center">
                            <Title text="Scenarios Requiring Attention" level="H4"/>
                            <Button text="Create Scenario" icon="sap-icon://create-form" type="Transparent" press=".goCreateScenario"/>
                          </HBox>
                          <Table items="{app>/dashboard/scenariosRequiringAttention}" noDataText="No scenarios currently require attention.">
                            <columns>
                              <Column><Text text="Scenario"/></Column>
                              <Column><Text text="Model"/></Column>
                              <Column><Text text="Risk"/></Column>
                              <Column><Text text="Compliance"/></Column>
                              <Column><Text text="Delay"/></Column>
                              <Column><Text text="Most Impacted Area"/></Column>
                              <Column><Text text="Action"/></Column>
                            </columns>
                            <items>
                              <ColumnListItem>
                                <cells>
                                  <ObjectIdentifier title="{app>scenarioName}" text="{app>scenarioId}"/>
                                  <ObjectStatus text="{app>businessModelType}" state="Information"/>
                                  <ObjectNumber number="{app>riskScore}" unit="%"/>
                                  <ObjectNumber number="{app>complianceRisk}" unit="%"/>
                                  <ObjectNumber number="{app>delayProbability}" unit="%"/>
                                  <Text text="{app>mostImpactedArea}"/>
                                  <Button text="Open Impact Analysis" icon="sap-icon://journey-arrive" type="Transparent" press=".openImpactFromRow"/>
                                </cells>
                              </ColumnListItem>
                            </items>
                          </Table>
                        </VBox>
                        <VBox class="panel">
                          <Title text="Recent Scenario Activity" level="H4"/>
                          <List items="{app>/dashboard/recentActivity}" noDataText="No recent activity yet.">
                            <StandardListItem title="{app>scenarioName}" description="{app>timestamp}" info="{app>recommendationStatus}" infoState="Information"/>
                          </List>
                        </VBox>
                      </HBox>
                      </VBox>
                    </VBox>
                  </IconTabFilter>

                  <IconTabFilter key="create" icon="sap-icon://create-form" text="Create Scenario">
                    <VBox class="panel formPanel createScenarioPage">
                      <VBox class="createScenarioHeader">
                        <Title text="Scenario Builder" level="H3"/>
                        <Text text="Create a commercial model scenario with stable enterprise parameters for O2C impact analysis."/>
                      </VBox>
                      <MessageStrip class="createScenarioMessage" text="Enter scenario parameters manually. Dropdowns provide common enterprise values while keeping fields editable." type="Information" showIcon="true"/>
                      <MessageStrip class="createScenarioMessage" text="{app>/formError}" type="Error" showIcon="true" visible="{= !!${app>/formError} }"/>

                      <VBox class="createScenarioForm">
                        <VBox class="createScenarioSection">
                          <Title text="Scenario Basics" level="H4"/>
                          <VBox class="createScenarioGrid">
                            <VBox class="createScenarioField"><Label text="Scenario Name" required="true"/><Input width="100%" value="{app>/newScenario/name}" required="true"/></VBox>
                            <VBox class="createScenarioField"><Label text="Industry"/><ComboBox width="100%" value="{app>/newScenario/industry}" items="{app>/referenceData/fields/industries}" placeholder="Enter or select industry"><core:Item key="{app>}" text="{app>}"/></ComboBox></VBox>
                            <VBox class="createScenarioField createScenarioWideField"><Label text="Description"/><TextArea width="100%" height="6rem" rows="4" growing="false" value="{app>/newScenario/description}"/></VBox>
                            <VBox class="createScenarioField"><Label text="Customer Segment"/><ComboBox width="100%" value="{app>/newScenario/customerSegment}" items="{app>/referenceData/fields/customerSegments}" placeholder="Enter or select customer segment"><core:Item key="{app>}" text="{app>}"/></ComboBox></VBox>
                            <VBox class="createScenarioField"><Label text="Region"/><ComboBox width="100%" value="{app>/newScenario/region}" items="{app>/referenceData/fields/regions}" placeholder="Enter primary region or market scope"><core:Item key="{app>}" text="{app>}"/></ComboBox></VBox>
                          </VBox>
                        </VBox>

                        <VBox class="createScenarioSection">
                          <Title text="Commercial Model" level="H4"/>
                          <VBox class="createScenarioGrid">
                            <VBox class="createScenarioField"><Label text="Business Model Type"/><ComboBox width="100%" value="{app>/newScenario/businessModelType}" items="{app>/referenceData/fields/businessModelTypes}" placeholder="Enter or select commercial model"><core:Item key="{app>}" text="{app>}"/></ComboBox></VBox>
                            <VBox class="createScenarioField"><Label text="Pricing Type"/><ComboBox width="100%" value="{app>/newScenario/pricingType}" items="{app>/referenceData/fields/pricingTypes}" placeholder="Enter or select pricing approach"><core:Item key="{app>}" text="{app>}"/></ComboBox></VBox>
                            <VBox class="createScenarioField"><Label text="Contract Term"/><ComboBox width="100%" value="{app>/newScenario/contractTerm}" placeholder="e.g. 12 Months, 24 Months, No Fixed Contract"><items><core:Item key="12" text="12 Months"/><core:Item key="24" text="24 Months"/><core:Item key="36" text="36 Months"/><core:Item key="1" text="No Fixed Contract"/></items></ComboBox></VBox>
                            <VBox class="createScenarioField"><Label text="Bundle Type"/><ComboBox width="100%" value="{app>/newScenario/bundleType}" items="{app>/referenceData/fields/bundleTypes}" placeholder="Enter bundle components"><core:Item key="{app>}" text="{app>}"/></ComboBox></VBox>
                          </VBox>
                        </VBox>

                        <VBox class="createScenarioSection">
                          <Title text="Billing and Funding" level="H4"/>
                          <VBox class="createScenarioGrid">
                            <VBox class="createScenarioField"><Label text="Billing Frequency"/><ComboBox width="100%" value="{app>/newScenario/billingFrequency}" items="{app>/referenceData/fields/billingFrequencies}" placeholder="Enter or select billing cadence"><core:Item key="{app>}" text="{app>}"/></ComboBox></VBox>
                            <VBox class="createScenarioField"><Label text="Funding Model"/><ComboBox width="100%" value="{app>/newScenario/fundingModel}" items="{app>/referenceData/fields/fundingModels}" placeholder="Enter or select funding style"><core:Item key="{app>}" text="{app>}"/></ComboBox></VBox>
                          </VBox>
                        </VBox>

                        <VBox class="createScenarioSection">
                          <Title text="Operational Complexity" level="H4"/>
                          <VBox class="createScenarioGrid">
                            <VBox class="createScenarioField"><Label text="Transaction Volume"/><HBox class="createScenarioInline"><ComboBox width="100%" selectedKey="{app>/newScenario/transactionVolumeBand}" items="{app>/referenceData/fields/transactionVolumeBands}" placeholder="Select volume band"><core:Item key="{app>value}" text="{app>label}"/></ComboBox><Input width="100%" value="{app>/newScenario/transactionVolume}" type="Number" placeholder="Optional numeric override"/></HBox></VBox>
                            <VBox class="createScenarioField"><Label text="Expected Revenue"/><HBox class="createScenarioInline"><ComboBox width="100%" selectedKey="{app>/newScenario/expectedRevenueBand}" items="{app>/referenceData/fields/expectedRevenueBands}" placeholder="Select revenue band"><core:Item key="{app>value}" text="{app>label}"/></ComboBox><Input width="100%" value="{app>/newScenario/expectedRevenue}" type="Number" placeholder="Optional numeric override"/></HBox></VBox>
                            <VBox class="createScenarioField"><Label text="Integration Count"/><StepInput width="100%" value="{app>/newScenario/integrationCount}" min="0" max="100"/></VBox>
                            <VBox class="createScenarioField"><Label text="Process Complexity"/><ComboBox width="100%" selectedKey="{app>/newScenario/processComplexityBand}" items="{app>/referenceData/fields/processComplexities}" placeholder="Select complexity"><core:Item key="{app>value}" text="{app>label}"/></ComboBox></VBox>
                          </VBox>
                        </VBox>

                        <VBox class="createScenarioSection">
                          <Title text="Compliance and Integrations" level="H4"/>
                          <VBox class="createScenarioGrid">
                            <VBox class="createScenarioField createScenarioWideField"><Label text="Compliance Regions"/><MultiComboBox width="100%" selectedKeys="{app>/newScenario/complianceRegions}" items="{app>/referenceData/fields/complianceRegions}" placeholder="Select compliance regions"><core:Item key="{app>}" text="{app>}"/></MultiComboBox></VBox>
                            <VBox class="createScenarioField createScenarioWideField"><Label text="Additional Compliance Regions"/><Input width="100%" value="{app>/newScenario/complianceRegionsText}" placeholder="Optional comma-separated custom regions"/></VBox>
                          </VBox>
                        </VBox>
                      </VBox>

                      <HBox class="createScenarioActions" justifyContent="End"><Button text="Save Scenario" icon="sap-icon://save" type="Transparent" press=".onCreateScenario" enabled="{= !${app>/loading/createScenario} }"/><Button text="Save and Run Impact Analysis" icon="sap-icon://begin" type="Emphasized" press=".onCreateAndAnalyzeScenario" enabled="{= !${app>/loading/createScenario} }"/></HBox>
                    </VBox>
                  </IconTabFilter>

                  <IconTabFilter key="compare" icon="sap-icon://compare" text="Compare Scenarios">
                    <VBox class="pageStack">
                      <VBox class="panel">
                        <HBox justifyContent="SpaceBetween" alignItems="Center"><VBox><Title text="Scenario Comparison" level="H3"/><Text text="{app>/comparisonDetails/bestFitRecommendation}"/></VBox><Button text="Compare All Scenarios" icon="sap-icon://compare" type="Emphasized" press=".onCompareAll"/></HBox>
                        <MessageStrip text="{app>/comparisonDetails/tradeOffExplanation}" type="Information" showIcon="true"/>
                        <Table items="{app>/comparison}" noDataText="Create at least two scenarios, then compare.">
                          <columns><Column><Text text="Rank"/></Column><Column><Text text="Scenario"/></Column><Column><Text text="Model"/></Column><Column><Text text="Recommendation"/></Column><Column><Text text="Risk"/></Column><Column><Text text="Revenue"/></Column><Column><Text text="Effort"/></Column><Column><Text text="Compliance"/></Column><Column><Text text="Delay"/></Column><Column><Text text="Dependencies"/></Column><Column hAlign="End"><Text text="Action"/></Column></columns>
                          <items><ColumnListItem><cells><ObjectNumber number="{app>rank}"/><ObjectIdentifier title="{app>name}" text="{app>businessModelType}"/><ObjectStatus text="{app>businessModelType}" state="Information"/><ObjectStatus text="{app>recommendationScore}" state="Success"/><ObjectNumber number="{app>risk}" unit="%"/><ObjectNumber number="{app>revenueImpact}" unit="%"/><ObjectNumber number="{app>implementationEffort}" unit="%"/><ObjectNumber number="{app>compliance}" unit="%"/><ObjectNumber number="{app>delayProbability}" unit="%"/><ObjectNumber number="{app>dependencyCount}"/><Button icon="sap-icon://delete" text="Delete" type="Transparent" tooltip="Delete scenario" press=".onDeleteScenarioFromCompare" enabled="{= !${app>/loading/deleteScenario} }"/></cells></ColumnListItem></items>
                        </Table>
                      </VBox>
                      <HBox class="sectionGrid">
                        <VBox class="panel chartPanel"><Title text="Revenue Impact Comparison" level="H4"/><List items="{app>/comparisonDetails/charts/revenueImpactComparison}" noDataText="No comparison data."><CustomListItem><VBox class="chartRow"><HBox justifyContent="SpaceBetween"><Text text="{app>label}"/><ObjectNumber number="{app>value}" unit="%"/></HBox><HBox class="barTrack"><HBox class="barFill revenueBar" width="{app>barWidth}"/></HBox></VBox></CustomListItem></List></VBox>
                        <VBox class="panel chartPanel"><Title text="Risk Score Comparison" level="H4"/><List items="{app>/comparisonDetails/charts/riskComparison}" noDataText="No comparison data."><CustomListItem><VBox class="chartRow"><HBox justifyContent="SpaceBetween"><Text text="{app>label}"/><ObjectNumber number="{app>value}" unit="%"/></HBox><HBox class="barTrack"><HBox class="barFill riskBar" width="{app>barWidth}"/></HBox></VBox></CustomListItem></List></VBox>
                        <VBox class="panel chartPanel"><Title text="Dependency Count Comparison" level="H4"/><List items="{app>/comparisonDetails/charts/dependencyCountComparison}" noDataText="No comparison data."><CustomListItem><VBox class="chartRow"><HBox justifyContent="SpaceBetween"><Text text="{app>label}"/><ObjectNumber number="{app>value}"/></HBox><HBox class="barTrack"><HBox class="barFill dependencyBar" width="{app>barWidth}"/></HBox></VBox></CustomListItem></List></VBox>
                      </HBox>
                    </VBox>
                  </IconTabFilter>

                  <IconTabFilter key="impact" icon="sap-icon://journey-arrive" text="Impact Analysis">
                    <VBox class="pageStack">
                      <VBox class="panel">
                        <HBox justifyContent="SpaceBetween" alignItems="Center">
                          <VBox><Title text="{app>/impactDetails/scenarioOverview/name}" level="H3"/><Text text="{app>/impactDetails/scenarioOverview/industry} | {app>/impactDetails/scenarioOverview/region} | {app>/impactDetails/scenarioOverview/billingFrequency} billing"/></VBox>
                          <HBox><Button text="Run Analysis" icon="sap-icon://begin" type="Transparent" press=".onAnalyzeSelected"/><Button text="Suggest Better Business Model" icon="sap-icon://ai" type="Emphasized" press=".onSuggestBetterModel" visible="{= !!${app>/analysis} }" enabled="{= !${app>/loading/suggestion} }"/></HBox>
                        </HBox>
                        <FlexBox wrap="Wrap" class="overviewStrip">
                          <ObjectStatus title="Model" text="{app>/impactDetails/scenarioOverview/businessModelType}" state="Information"/>
                          <ObjectStatus title="Contract" text="{app>/impactDetails/scenarioOverview/contractTerm} months" state="None"/>
                          <ObjectStatus title="Volume" text="{app>/impactDetails/scenarioOverview/transactionVolume}" state="None"/>
                          <ObjectStatus title="Confidence" text="{path:'app>/impactDetails/predictiveAi/confidenceScore', formatter:'.confidenceText'}" state="Success"/>
                        </FlexBox>
                        <MessageStrip text="{app>/suggestionProgress}" type="Information" showIcon="true" visible="{= !!${app>/loading/suggestion} || !!${app>/suggestionProgress} }"/>
                        <VBox class="errorPanel" visible="{= !!${app>/suggestionError} }">
                          <MessageStrip text="{app>/suggestionError/message}" type="Error" showIcon="true"/>
                          <Text text="{app>/suggestionError/details}"/>
                          <HBox justifyContent="End"><Button text="Retry" icon="sap-icon://restart" type="Emphasized" press=".onRetrySuggestion"/></HBox>
                        </VBox>
                      </VBox>
                      <HBox class="sectionGrid">
                        <VBox class="panel widePanel">
                          <Title text="O2C Impact Matrix" level="H3"/>
                          <Table items="{app>/impactDetails/areaDetails}" noDataText="Run analysis to view O2C impact details.">
                            <columns><Column><Text text="Area"/></Column><Column><Text text="Score"/></Column><Column><Text text="Reason"/></Column><Column><Text text="Affected Systems"/></Column><Column><Text text="Required Changes"/></Column><Column><Text text="Dependencies"/></Column></columns>
                            <items><ColumnListItem><cells><ObjectIdentifier title="{app>label}" text="{app>severity}"/><ObjectStatus text="{app>score}" state="{app>state}"/><Text text="{app>reason}"/><Text text="{path:'app>affectedSystems', formatter:'.joinList'}"/><Text text="{path:'app>requiredChanges', formatter:'.joinList'}"/><ObjectNumber number="{app>dependencyCount}"/></cells></ColumnListItem></items>
                          </Table>
                        </VBox>
                        <VBox class="panel">
                          <Title text="Risk and Effort" level="H3"/>
                          <List items="{app>/impactDetails/riskMetrics}"><CustomListItem><VBox class="chartRow"><HBox justifyContent="SpaceBetween"><ObjectStatus text="{app>name}" state="{app>state}"/><ObjectNumber number="{app>value}" unit="%"/></HBox><HBox class="barTrack"><HBox class="barFill riskBar" width="{app>value}%"/></HBox></VBox></CustomListItem></List>
                        </VBox>
                      </HBox>
                      <HBox class="sectionGrid">
                        <VBox class="panel chartPanel"><Title text="O2C Impact by Area" level="H4"/><List items="{app>/scenarioCharts/o2cImpactByArea}" noDataText="No chart data."><CustomListItem><VBox class="chartRow"><HBox justifyContent="SpaceBetween"><Text text="{app>label}"/><ObjectStatus text="{app>value}" state="{path:'app>value', formatter:'.scoreState'}"/></HBox><HBox class="barTrack"><HBox class="barFill impactBar" width="{app>barWidth}"/></HBox></VBox></CustomListItem></List></VBox>
                        <VBox class="panel chartPanel"><Title text="Dependency Distribution" level="H4"/><List items="{app>/scenarioCharts/dependencyDistribution}" noDataText="No dependency data."><CustomListItem><VBox class="chartRow"><HBox justifyContent="SpaceBetween"><Text text="{app>label}"/><ObjectNumber number="{app>value}"/></HBox><HBox class="barTrack"><HBox class="barFill dependencyBar" width="{app>barWidth}"/></HBox></VBox></CustomListItem></List></VBox>
                        <VBox class="panel chartPanel"><Title text="Severity Breakdown" level="H4"/><List items="{app>/scenarioCharts/severityBreakdown}" noDataText="No severity data."><CustomListItem><VBox class="chartRow"><HBox justifyContent="SpaceBetween"><Text text="{app>label}"/><ObjectNumber number="{app>value}"/></HBox><HBox class="barTrack"><HBox class="barFill performanceBar" width="{app>barWidth}"/></HBox></VBox></CustomListItem></List></VBox>
                      </HBox>
                      <VBox class="panel" visible="{app>/suggestionVisible}">
                        <HBox justifyContent="SpaceBetween" alignItems="Center"><VBox><Title text="AI-Suggested Better Business Model" level="H3"/><Text text="{app>/suggestion/improvementSummary}"/></VBox><ObjectStatus text="{app>/suggestion/confidence}" state="Success"/></HBox>
                        <MessageStrip text="{app>/suggestion/message}" type="Success" showIcon="true" visible="{app>/suggestion/noBetterModelFound}"/>
                        <MessageStrip text="{app>/suggestion/aiRationale}" type="Information" showIcon="true"/>
                        <Table items="{app>/suggestion/scoreRows}"><columns><Column><Text text="Measure"/></Column><Column><Text text="Current"/></Column><Column><Text text="Suggested"/></Column></columns><items><ColumnListItem><cells><Text text="{app>name}"/><ObjectNumber number="{app>original}"/><ObjectNumber number="{app>suggested}"/></cells></ColumnListItem></items></Table>
                        <HBox class="sectionGrid"><VBox><Title text="Suggested Scenario" level="H4"/><Text text="{app>/suggestion/suggestedScenario/name}"/><ObjectStatus text="{app>/suggestion/suggestedScenario/businessModelType}" state="Information"/><Text text="{app>/suggestion/suggestedScenario/pricingType} pricing | {app>/suggestion/suggestedScenario/billingFrequency} billing"/></VBox><VBox><Title text="Expected Benefits" level="H4"/><Text text="Revenue improvement: {app>/suggestion/revenueImprovement}%"/><Text text="Risk reduction: {app>/suggestion/riskReduction}%"/><Text text="Effort change: {app>/suggestion/effortChange}%"/></VBox></HBox>
                        <HBox justifyContent="End"><Button text="Discard Suggestion" icon="sap-icon://decline" type="Transparent" press=".onDiscardSuggestion" enabled="{parts:[{path:'app>/suggestion/suggestionId'},{path:'app>/suggestion/status'},{path:'app>/loading/recommendationAction'}], formatter:'.canDiscardSuggestion'}"/><Button text="Compare With Current Model" icon="sap-icon://compare" press=".onCompareSuggestion" enabled="{parts:[{path:'app>/selectedScenario'},{path:'app>/suggestion/suggestedScenario'},{path:'app>/loading/recommendationAction'},{path:'app>/suggestion/status'}], formatter:'.canCompareSuggestion'}"/><Button text="Use Suggested Model" icon="sap-icon://accept" type="Emphasized" press=".onUseSuggestedModel" enabled="{parts:[{path:'app>/suggestion/suggestionId'},{path:'app>/suggestion/status'},{path:'app>/loading/recommendationAction'},{path:'app>/suggestion/suggestedScenario'}], formatter:'.canUseSuggestion'}"/></HBox>
                      </VBox>
                    </VBox>
                  </IconTabFilter>

                  <IconTabFilter key="prediction" icon="sap-icon://machine" text="Prediction Details">
                    <HBox class="sectionGrid">
                      <VBox class="panel"><Title text="Predictive Outputs" level="H3"/><List items="{app>/analysis/predictionRows}"><CustomListItem><HBox class="metricRow" justifyContent="SpaceBetween"><Text text="{app>name}"/><ObjectNumber number="{app>score}"/></HBox></CustomListItem></List></VBox>
                      <VBox class="panel"><Title text="Explainability" level="H3"/><ProgressIndicator percentValue="{path:'app>/analysis/prediction/confidence', formatter:'.confidencePct'}" displayValue="{path:'app>/analysis/prediction/confidence', formatter:'.confidenceText'}"/><List items="{app>/analysis/prediction/topContributingFactors}"><StandardListItem title="{app>factor}" description="Business driver weight {app>importance}"/></List></VBox>
                    </HBox>
                  </IconTabFilter>

                  <IconTabFilter key="recommendation" icon="sap-icon://ai" text="AI Recommendation">
                    <VBox class="pageStack">
                      <MessageStrip text="{app>/recommendationError}" type="Error" showIcon="true" visible="{= !!${app>/recommendationError} }"/>
                      <MessageStrip text="{app>/recommendationProgress}" type="Information" showIcon="true" visible="{= !!${app>/recommendationProgress} }"/>
                      <VBox class="panel errorPanel" visible="{= !!${app>/recommendationView/predictiveOnly} }">
                        <Title text="AI recommendation is temporarily unavailable" level="H3"/>
                        <MessageStrip text="{app>/recommendationView/customerMessage}" type="Warning" showIcon="true"/>
                        <Text text="Predictive impact scores, historical analysis and O2C impact details remain available for review."/>
                        <HBox justifyContent="End"><Button text="View Predictive Impact Details" icon="sap-icon://machine" type="Transparent" press=".onViewPredictionDetails"/><Button text="Retry Recommendation" icon="sap-icon://refresh" type="Emphasized" press=".onRegenerateRecommendation" enabled="{= !${app>/loading/recommendation} }"/></HBox>
                      </VBox>
                      <VBox class="panel aiHero">
                        <HBox justifyContent="SpaceBetween" alignItems="Center">
                          <VBox>
                            <Title text="AI Recommendation Workspace" level="H3"/>
                            <Text text="{app>/recommendationView/originalScenario/name}"/>
                            <ObjectStatus text="{app>/recommendationView/recommendationStatus}" state="Information"/>
                          </VBox>
                          <VBox alignItems="End">
                            <ObjectStatus text="{app>/recommendationView/recommendedModel}" state="Success"/>
                            <Text text="{app>/recommendationView/audit/generatedAt}"/>
                            <ObjectNumber number="{app>/recommendationView/confidence}" unit="confidence"/>
                          </VBox>
                        </HBox>
                      </VBox>
                      <HBox class="sectionGrid">
                        <VBox class="panel widePanel executivePanel" visible="{= !${app>/recommendationView/predictiveOnly} }">
                          <HBox justifyContent="SpaceBetween" alignItems="Center"><Title text="Executive Recommendation" level="H3"/><ObjectStatus text="{app>/recommendationView/recommendedModel}" state="Success"/></HBox>
                          <MessageStrip text="{app>/recommendationView/executiveSummary}" type="Information" showIcon="true"/>
                          <HBox class="sectionGrid">
                            <VBox class="miniCard"><Title text="Expected Business Value" level="H5"/><Text text="{app>/recommendationView/improvementSummary}"/></VBox>
                            <VBox class="miniCard"><Title text="Recommendation Badge" level="H5"/><ObjectStatus text="{app>/recommendationView/recommendationStatus}" state="Information"/></VBox>
                            <VBox class="miniCard"><Title text="Confidence" level="H5"/><ProgressIndicator percentValue="{path:'app>/recommendationView/confidence', formatter:'.confidencePct'}" displayValue="{path:'app>/recommendationView/confidence', formatter:'.confidenceText'}"/></VBox>
                          </HBox>
                        </VBox>
                        <VBox class="panel widePanel predictiveExecutivePanel" visible="{= !!${app>/recommendationView/predictiveOnly} }">
                          <HBox justifyContent="SpaceBetween" alignItems="Center">
                            <Title text="Predictive Executive Readout" level="H3"/>
                            <ObjectStatus text="Predictive AI Active" state="Information"/>
                          </HBox>
                          <MessageStrip text="{app>/recommendationView/predictiveAnalysis/historicalPatternSummary}" type="Information" showIcon="true"/>
                          <HBox class="sectionGrid">
                            <VBox class="miniCard"><Title text="Current Model" level="H5"/><Text text="{app>/recommendationView/originalScenario/businessModelType}"/></VBox>
                            <VBox class="miniCard"><Title text="Risk Position" level="H5"/><ObjectNumber number="{app>/recommendationView/originalPrediction/riskScore}" unit="risk score"/></VBox>
                            <VBox class="miniCard"><Title text="Revenue Outlook" level="H5"/><ObjectNumber number="{app>/recommendationView/originalPrediction/revenueImpact}" unit="%"/></VBox>
                            <VBox class="miniCard"><Title text="Predictive Confidence" level="H5"/><ProgressIndicator percentValue="{path:'app>/recommendationView/predictiveAnalysis/confidence', formatter:'.confidencePct'}" displayValue="{path:'app>/recommendationView/predictiveAnalysis/confidence', formatter:'.confidenceText'}"/></VBox>
                          </HBox>
                        </VBox>
                        <VBox class="panel recommendationActionsPanel">
                          <Title text="Recommendation Actions" level="H3"/>
                          <Text class="actionHint" text="Use predictive AI plus Ollama to generate an alternative model before applying or comparing changes." visible="{= !${app>/recommendationView/suggestionId} }"/>
                          <VBox class="actionButtonStack">
                            <Button text="Suggest Better Business Model" icon="sap-icon://ai" type="Emphasized" press=".onSuggestBetterModel" enabled="{parts:[{path:'app>/loading/suggestion'},{path:'app>/loading/recommendationAction'},{path:'app>/recommendationView/predictiveOnly'},{path:'app>/recommendationView/originalPrediction'}], formatter:'.canRequestSuggestion'}"/>
                            <Button text="Regenerate Executive Recommendation" icon="sap-icon://refresh" type="Transparent" press=".onRegenerateRecommendation" enabled="{= !${app>/loading/recommendation} }"/>
                            <Button text="Use Suggested Model" icon="sap-icon://accept" press=".onUseSuggestedModel" visible="{= !!${app>/recommendationView/suggestionId} }" enabled="{parts:[{path:'app>/recommendationView/suggestionId'},{path:'app>/recommendationView/suggestionStatus'},{path:'app>/loading/recommendationAction'},{path:'app>/recommendationView/suggestedScenario'}], formatter:'.canUseSuggestion'}"/>
                            <Button text="Compare With Current Model" icon="sap-icon://compare" type="Transparent" press=".onCompareSuggestion" visible="{= !!${app>/recommendationView/suggestionId} }" enabled="{parts:[{path:'app>/recommendationView/originalScenario'},{path:'app>/recommendationView/suggestedScenario'},{path:'app>/loading/recommendationAction'},{path:'app>/recommendationView/suggestionStatus'}], formatter:'.canCompareSuggestion'}"/>
                            <Button text="Discard Suggestion" icon="sap-icon://decline" type="Transparent" press=".onDiscardSuggestion" visible="{= !!${app>/recommendationView/suggestionId} }" enabled="{parts:[{path:'app>/recommendationView/suggestionId'},{path:'app>/recommendationView/suggestionStatus'},{path:'app>/loading/recommendationAction'}], formatter:'.canDiscardSuggestion'}"/>
                          </VBox>
                          <MessageStrip text="{app>/suggestionProgress}" type="Information" showIcon="true" visible="{= !!${app>/loading/suggestion} || !!${app>/suggestionProgress} }"/>
                          <MessageStrip text="{app>/suggestionError/message}" type="Error" showIcon="true" visible="{= !!${app>/suggestionError} }"/>
                        </VBox>
                      </HBox>
                      <VBox class="panel">
                        <Title text="Predictive AI Historical Analysis" level="H3"/>
                        <Text text="{app>/recommendationView/predictiveAnalysis/historicalPatternSummary}"/>
                        <HBox class="sectionGrid">
                          <VBox class="miniCard"><Title text="Model Version" level="H5"/><Text text="{app>/recommendationView/predictiveAnalysis/modelVersion}"/></VBox>
                          <VBox class="miniCard"><Title text="Predictive Confidence" level="H5"/><ProgressIndicator percentValue="{path:'app>/recommendationView/predictiveAnalysis/confidence', formatter:'.confidencePct'}" displayValue="{path:'app>/recommendationView/predictiveAnalysis/confidence', formatter:'.confidenceText'}"/></VBox>
                        </HBox>
                        <List items="{app>/recommendationView/predictiveAnalysis/riskDrivers}" noDataText="Predictive driver details are not available for this scenario.">
                          <CustomListItem>
                            <VBox class="reasonCard">
                              <HBox justifyContent="SpaceBetween" alignItems="Center"><Title text="{app>title}" level="H5"/><ObjectStatus text="{app>severity}" state="{path:'app>severity', formatter:'.severityState'}"/></HBox>
                              <Text text="{app>businessMeaning}"/>
                              <Text text="{app>whyItMatters}"/>
                            </VBox>
                          </CustomListItem>
                        </List>
                      </VBox>
                      <HBox class="sectionGrid">
                        <VBox class="panel widePanel" visible="{= !${app>/recommendationView/predictiveOnly} }">
                          <Title text="Why AI Recommended This" level="H3"/>
                          <List items="{app>/recommendationView/customerFriendlyReasoning}" noDataText="Run analysis to view customer-friendly AI reasoning.">
                            <CustomListItem>
                              <VBox class="reasonCard">
                                <HBox justifyContent="SpaceBetween" alignItems="Center"><Title text="{app>title}" level="H5"/><ObjectStatus text="{app>severity}" state="{path:'app>severity', formatter:'.severityState'}"/></HBox>
                                <Text text="{app>businessMeaning}"/>
                                <Text text="{app>whyItMatters}"/>
                                <HBox justifyContent="SpaceBetween"><ObjectStatus text="{app>impactArea}" state="Information"/><Text text="Driver weight {app>importanceScore}"/></HBox>
                              </VBox>
                            </CustomListItem>
                          </List>
                          <MessageStrip text="{app>/recommendationView/aiRationale}" type="Information" showIcon="true" visible="{= !!${app>/recommendationView/aiRationale} }"/>
                        </VBox>
                        <VBox class="panel">
                          <Title text="Risk and Benefit Breakdown" level="H3"/>
                          <List items="{app>/recommendationView/riskAndBenefitBreakdown}">
                            <CustomListItem><HBox class="metricRow" justifyContent="SpaceBetween"><VBox><Text text="{app>label}"/><Text text="{app>source}"/></VBox><ObjectNumber number="{app>value}" unit="{app>unit}"/></HBox></CustomListItem>
                          </List>
                        </VBox>
                      </HBox>
                      <VBox class="panel">
                        <Title text="Current vs Suggested Model" level="H3"/>
                        <Table items="{app>/recommendationView/comparisonRows}" noDataText="No suggested model is available yet. Use Suggest Better Business Model to compare alternatives.">
                          <columns><Column><Text text="Measure"/></Column><Column><Text text="Current"/></Column><Column><Text text="Suggested"/></Column><Column><Text text="Change"/></Column></columns>
                          <items><ColumnListItem><cells><Text text="{app>name}"/><Text text="{app>original}"/><Text text="{app>suggested}"/><ObjectStatus text="{app>changeText}" state="{app>changeState}"/></cells></ColumnListItem></items>
                        </Table>
                      </VBox>
                      <HBox class="sectionGrid" visible="{= !${app>/recommendationView/predictiveOnly} }">
                        <VBox class="panel"><Title text="Assumptions" level="H3"/><List items="{app>/recommendationView/assumptions}" noDataText="No AI assumptions available."><StandardListItem title="{app>}"/></List></VBox>
                        <VBox class="panel"><Title text="Trade-Offs" level="H3"/><List items="{app>/recommendationView/tradeOffs}" noDataText="No AI trade-offs available."><StandardListItem title="{app>}"/></List></VBox>
                        <VBox class="panel"><Title text="Audit Trail" level="H3"/><Text text="Source scenario: {app>/recommendationView/sourceScenarioId}"/><Text text="Suggestion: {app>/recommendationView/suggestionId}"/><Text text="Prompt version: {app>/recommendationView/audit/promptVersion}"/><Text text="Generated: {app>/recommendationView/audit/generatedAt}"/><Text text="Model: {app>/recommendationView/audit/model}"/></VBox>
                      </HBox>
                    </VBox>
                  </IconTabFilter>

                  <IconTabFilter key="audit" icon="sap-icon://history" text="History / Audit Trail">
                    <VBox class="panel"><Title text="Audit Trail" level="H3"/><Table items="{app>/audit}"><columns><Column><Text text="Time"/></Column><Column><Text text="Action"/></Column><Column><Text text="Model"/></Column><Column><Text text="Prompt"/></Column></columns><items><ColumnListItem><cells><Text text="{app>timestamp}"/><ObjectStatus text="{app>action}" state="Information"/><Text text="{app>modelVersion}"/><Text text="{app>promptVersion}"/></cells></ColumnListItem></items></Table></VBox>
                  </IconTabFilter>

                  <IconTabFilter key="admin" icon="sap-icon://settings" text="Admin / Settings">
                    <VBox class="panel"><Title text="Service Health" level="H3"/><ObjectStatus text="{app>/health/status}" state="Success"/><Text text="AI provider: {app>/health/aiProvider}"/><Text text="AI model: {app>/health/aiModel}"/><Text text="AI configured: {app>/health/aiConfigured}"/><Text text="ML model: {app>/health/ml/modelVersion}"/><Text text="Dataset rows: {app>/health/ml/datasetRows}"/><Text text="Training rows: {app>/health/ml/trainingRows}"/><Text text="Test rows: {app>/health/ml/testRows}"/><Text text="Last trained: {app>/health/ml/trainedAt}"/><HBox><Button text="Check Health" icon="sap-icon://sys-enter-2" press=".loadHealth"/><Button text="Train Predictive Model" icon="sap-icon://machine" type="Emphasized" press=".onTrain"/></HBox></VBox>
                  </IconTabFilter>
                </items>
              </IconTabBar>
            </VBox>
          </ScrollContainer>
        </HBox>
      </content>
    </Page>
    </App>
  </VBox>
</mvc:View>
